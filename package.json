{
  "name": "phemex-cli",
  "version": "2.0.0",
  "main": "./dist/cli.js",
  "type": "module",
  "bin": {
    "phemex-cli": "./dist/cli.js"
  },
  "files": [
    "dist",
    "skill"
  ],
  "scripts": {
    "build": "tsc && node -e \"const fs=require('fs');const s='#!/usr/bin/env node\\n';['dist/cli.js'].forEach(f=>{const c=fs.readFileSync(f,'utf8');if(!c.startsWith('#!'))fs.writeFileSync(f,s+c)})\"",
    "start": "node dist/cli.js --help",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "phemex",
    "phemex-api",
    "trading",
    "trading-bot",
    "futures",
    "perpetual",
    "spot",
    "crypto",
    "cryptocurrency",
    "cli",
    "exchange",
    "bitcoin",
    "btc",
    "ethereum",
    "solana",
    "websocket",
    "market-data",
    "order-management",
    "ai-agent",
    "openclaw"
  ],
  "author": "Phemex",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "https://github.com/phemex/phemex-cli.git"
  },
  "homepage": "https://github.com/phemex/phemex-cli#readme",
  "bugs": {
    "url": "https://github.com/phemex/phemex-cli/issues"
  },
  "description": "Command-line interface for trading on Phemex — USDT-M futures, Coin-M futures, and Spot markets",
  "dependencies": {
    "dotenv": "^17.3.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.2.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
